# ============================================================
#  Affiliate Hub — Backend Configuration
#  Copy file này thành `.env` rồi điền các giá trị bên dưới.
#  Mỗi nhóm có note nói rõ ai bắt buộc, ai tuỳ chọn.
# ============================================================

# ---------- App core (mặc định OK, ít khi sửa) ----------
APP_NAME=Affiliate Hub
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
SESSION_COOKIE_NAME=ah_session
SESSION_TTL_HOURS=720
CORS_ORIGINS_RAW=http://localhost:3001
DATA_DIR=./data

# ---------- Stealth browser ----------
# CLOAK_BROWSER_PATH: bỏ trống → tự tải Chromium. Hoặc trỏ Chrome thật.
CLOAK_BROWSER_PATH=
# HEADLESS=true khi deploy server. false để xem trình duyệt khi dev/debug.
HEADLESS=false

# ============================================================
#  BẮT BUỘC điền để chạy auto-signup
# ============================================================

# ---------- LLM (Browser Agent) — BẮT BUỘC ít nhất 1 key ----------
# Gemini API key: https://aistudio.google.com/app/apikey  (FREE tier OK)
GEMINI_API_KEY=
# OpenAI fallback (tuỳ chọn): https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Model browser-use sẽ dùng. Khuyến nghị gemini-3.5-flash (rẻ + nhanh)
SIGNUP_LLM_MODEL=gemini-3.5-flash
# Số bước tối đa agent chạy / 1 site (60 = ~3 phút)
SIGNUP_MAX_STEPS=60

# ---------- CAPTCHA solver — BẮT BUỘC ----------
# Đa số site affiliate có Cloudflare Turnstile / reCAPTCHA / hCaptcha.
# Nạp $5-10 ở https://capsolver.com là dùng được rất lâu.
CAPSOLVER_API_KEY=

# ============================================================
#  TUỲ CHỌN — site nào yêu cầu thì mới cần
# ============================================================

# ---------- Proxy (khuyến nghị mạnh để tránh ban IP) ----------
# Residential rotating proxy. Format: http://user:pass@host:port  hoặc  socks5://host:port
# Gợi ý nhà cung cấp: BrightData / Oxylabs / Smartproxy / IPRoyal
PROXY_URL=
# Domain bỏ qua proxy (cách nhau dấu phẩy)
PROXY_BYPASS=localhost,127.0.0.1

# ---------- SMS OTP nhận mã (cho site yêu cầu phone verify) ----------
# Mặc định: smspool.net — tạo key ở https://www.smspool.net/my/settings (nạp tối thiểu $1)
# Country/Service ID: https://api.smspool.net/country/retrieve_all  |  /service/retrieve_all
# VD: VN=241, US=1 | Shopee=823, Any=1
SMS_OTP_PROVIDER=smspool          # smspool | 5sim | sms-activate
SMS_OTP_API_KEY=
SMS_OTP_COUNTRY=1                 # smspool: ID dạng số (1=US, 241=VN) | 5sim: "usa","vietnam"
SMS_OTP_OPERATOR=any              # smspool: pool ID hoặc "any" | 5sim: viettel/vinaphone/...
SMS_OTP_PRODUCT=1                 # smspool: service ID (1=Any, 823=Shopee) | 5sim: "any"/"shopee"
SMS_OTP_TIMEOUT_SEC=180

# ---------- Email verification IMAP (cho site verify qua email) ----------
# Gmail App Password: https://myaccount.google.com/apppasswords
# (Cần bật 2FA trước → tạo App Password, không phải mật khẩu Gmail thường)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SSL=true
IMAP_USER=
IMAP_PASSWORD=
IMAP_TIMEOUT_SEC=180

# ============================================================
#  Tích hợp tuỳ chọn (chỉ điền nếu dùng tính năng crawl SimilarWeb)
# ============================================================
SIMILARWEB_EMAIL=
SIMILARWEB_PASSWORD=
SELENIUM_HUB_URL=
NOVNC_URL=

